@page
@model Sion.PL.Pages.Admin.Account.ForgotPasswordModel
@{
    Layout = null;
    ViewData["Title"] = "Olvidé mi contraseña";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Restablecer contraseña | Proyecto Sion</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="sion-admin-login-body">
    <div class="sion-admin-login-box">
        <div class="sion-admin-login-logo">
            <img src="~/images/logo.png" alt="Proyecto Sion" height="56" />
            <div class="sion-admin-login-title">Restablecer contraseña</div>
        </div>

        @if (Model.Enviado)
        {
            <div style="text-align:center;padding:12px 0;color:#2d7a3a;font-size:0.9rem">
                Si el correo existe, recibirás un enlace en los próximos minutos.
            </div>
            <div class="mt-3 text-center">
                <a asp-page="/Admin/Account/Login" style="font-size:0.85rem;color:var(--sion-primary)">Volver al login</a>
            </div>
        }
        else
        {
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="sion-admin-login-error">@Model.ErrorMessage</div>
            }
            <p style="font-size:0.85rem;color:#666;margin-bottom:20px">
                Ingresá tu correo de administrador y te enviaremos un enlace para restablecer tu contraseña.
            </p>
            <form method="post">
                @Html.AntiForgeryToken()
                <div class="mb-4">
                    <label class="sion-form-label" asp-for="Email">Correo electrónico</label>
                    <input class="sion-form-control" asp-for="Email"
                           placeholder="admin@sioncr.org" autocomplete="email" />
                    <span class="sion-form-error" asp-validation-for="Email"></span>
                </div>
                <button type="submit" class="btn-sion-primary w-100">Enviar enlace</button>
            </form>
            <div class="mt-3 text-center">
                <a asp-page="/Admin/Account/Login" style="font-size:0.85rem;color:var(--sion-primary)">Volver al login</a>
            </div>
        }
    </div>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>