@page
@model Sion.PL.Pages.Admin.Account.ResetPasswordModel
@{
    Layout = null;
    ViewData["Title"] = "Nueva contraseña";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Nueva contraseña | Proyecto Sion</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="sion-admin-login-body">
    <div class="sion-admin-login-box">
        <div class="sion-admin-login-logo">
            <img src="~/images/logo.png" alt="Proyecto Sion" height="56" />
            <div class="sion-admin-login-title">Crear nueva contraseña</div>
        </div>

        @if (Model.Exitoso)
        {
            <div style="text-align:center;padding:12px 0;color:#2d7a3a;font-size:0.9rem">
                Contraseña actualizada correctamente.
            </div>
            <div class="mt-3 text-center">
                <a asp-page="/Admin/Account/Login" style="font-size:0.85rem;color:var(--sion-primary)">Ir al login</a>
            </div>
        }
        else if (Model.TokenInvalido)
        {
            <div class="sion-admin-login-error">
                El enlace no es válido o ya expiró. Solicitá uno nuevo.
            </div>
            <div class="mt-3 text-center">
                <a asp-page="/Admin/Account/ForgotPassword" style="font-size:0.85rem;color:var(--sion-primary)">Solicitar nuevo enlace</a>
            </div>
        }
        else
        {
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="sion-admin-login-error">@Model.ErrorMessage</div>
            }
            <form method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Input.Token" />
                <input type="hidden" asp-for="Input.Email" />
                <div class="mb-3">
                    <label class="sion-form-label" asp-for="Input.NuevaContrasena">Nueva contraseña</label>
                    <input class="sion-form-control" asp-for="Input.NuevaContrasena"
                           type="password" placeholder="Mínimo 6 caracteres" />
                    <span class="sion-form-error" asp-validation-for="Input.NuevaContrasena"></span>
                </div>
                <div class="mb-4">
                    <label class="sion-form-label" asp-for="Input.ConfirmarContrasena">Confirmá la contraseña</label>
                    <input class="sion-form-control" asp-for="Input.ConfirmarContrasena"
                           type="password" placeholder="Repetí la contraseña" />
                    <span class="sion-form-error" asp-validation-for="Input.ConfirmarContrasena"></span>
                </div>
                <button type="submit" class="btn-sion-primary w-100">Guardar contraseña</button>
            </form>
        }
    </div>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>