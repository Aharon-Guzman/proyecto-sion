@page
@model Sion.PL.Pages.Admin.Account.LoginModel
@{
    Layout = null;
    ViewData["Title"] = "Iniciar sesión";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Admin — Iniciar sesión | Proyecto Sion</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="sion-admin-login-body">
    <div class="sion-admin-login-box">
        <div class="sion-admin-login-logo">
            <img src="~/images/logo.png" alt="Proyecto Sion" height="56" />
            <div class="sion-admin-login-title">Panel Administrativo</div>
        </div>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="sion-admin-login-error">@Model.ErrorMessage</div>
        }

        <form method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label class="sion-form-label" asp-for="Input.Email">Correo electrónico</label>
                <input class="sion-form-control" asp-for="Input.Email"
                       placeholder="admin@sioncr.org" autocomplete="username" />
                <span class="sion-form-error" asp-validation-for="Input.Email"></span>
            </div>
            <div class="mb-3">
                <label class="sion-form-label" asp-for="Input.Password">Contraseña</label>
                <input class="sion-form-control" asp-for="Input.Password"
                       type="password" placeholder="••••••••" autocomplete="current-password" />
                <span class="sion-form-error" asp-validation-for="Input.Password"></span>
            </div>
            <div class="mb-4 d-flex align-items-center gap-2">
                <input type="checkbox" asp-for="Input.RememberMe" id="rememberMe" />
                <label for="rememberMe" style="font-size:0.9rem;color:var(--sion-muted)">Recordarme</label>
            </div>
            <button type="submit" class="btn-sion-primary w-100">Ingresar</button>
            <div class="mt-3 text-center">
                <a asp-page="/Admin/Account/ForgotPassword"
                   style="font-size:0.82rem;color:var(--sion-muted)">
                    ¿Olvidaste tu contraseña?
                </a>
            </div>
        </form>
    </div>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <div class="sion-login-waves" aria-hidden="true">
        <svg class="sion-login-wave sion-login-wave--blue"
             xmlns="http://www.w3.org/2000/svg"
             viewBox="0 0 1440 170"
             preserveAspectRatio="none">
            <path d="M0,85 C180,170 540,170 720,85 C900,0 1260,0 1440,85 L1440,170 L0,170 Z" />
        </svg>
        <svg class="sion-login-wave sion-login-wave--gold"
             xmlns="http://www.w3.org/2000/svg"
             viewBox="0 0 1440 120"
             preserveAspectRatio="none">
            <path d="M0,60 C120,120 360,120 480,60 C600,0 840,0 960,60 C1080,120 1320,120 1440,60 L1440,120 L0,120 Z" />
        </svg>
    </div>
</body>
</html>