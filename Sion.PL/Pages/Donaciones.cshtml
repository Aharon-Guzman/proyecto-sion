@page
@model Sion.PL.Pages.DonacionesModel
@{
    ViewData["Title"] = "Donaciones";
    ViewData["Description"] = "Tu donación transforma vidas en Concepción de Tres Ríos. Apoyá al Proyecto Sion hoy.";
}

<!-- PAGE HERO -->
<section class="sion-page-hero">
    <div class="container sion-page-hero-content">
        <h1>Hacé una donación</h1>
        <p>Tu aporte nos permite seguir transformando vidas en Concepción de Tres Ríos.</p>
    </div>
</section>

<!-- DONACIÓN -->
<section class="sion-seccion">
    <div class="container">
        <div class="row g-5 align-items-start">

            <!-- PANEL DE DONACIÓN -->
            <div class="col-lg-6 sion-reveal-left">
                <span class="sion-badge">Tu aporte importa</span>
                <h2 class="mt-2 mb-4">Hacé tu donación</h2>

                @*
                    ============================================================
                    PAYPAL TEMPORALMENTE DESACTIVADO
                    La cuenta business de PayPal está pendiente de aprobación.
                    Para reactivar PayPal:
                      1. Eliminar el bloque de tarjeta SINPE de abajo (entre los comentarios INICIO/FIN SINPE)
                      2. Descomentar el bloque PAYPAL DESACTIVADO que le sigue
                      3. En el @section Scripts al final del archivo:
                         - Descomentar el script src de PayPal SDK
                         - Descomentar todo el bloque script de JS
                    ============================================================
                *@

                @* === INICIO BLOQUE SINPE (eliminar cuando PayPal esté listo) === *@
                <div class="sion-dona-sinpe-card text-center py-4 px-3">
                    <img src="~/images/Logo.png" alt="Proyecto Sion" class="sion-dona-logo mb-4" />

                    <p class="sion-dona-sinpe-texto mb-4">
                        Podés apoyarnos directamente a través de <strong>SINPE Móvil</strong>
                        o escribirnos por correo. Tu aporte llega al 100% a nuestra comunidad.
                    </p>

                    <div class="sion-dona-contacto-row">
                        <div class="sion-dona-contacto-icon sion-dona-icon-sinpe">📱</div>
                        <div class="text-start">
                            <p class="sion-dona-contacto-label">SINPE Móvil</p>
                            <p class="sion-dona-contacto-valor">+506 6486 9767</p>
                        </div>
                    </div>

                    <div class="sion-dona-contacto-row mt-2">
                        <div class="sion-dona-contacto-icon sion-dona-icon-email">✉️</div>
                        <div class="text-start">
                            <p class="sion-dona-contacto-label">Correo electrónico</p>
                            <p class="sion-dona-contacto-valor">
                                <a href="mailto:info@sioncr.org">info@sioncr.org</a>
                            </p>
                        </div>
                    </div>

                    <p class="sion-dona-nota mt-4 mb-0">
                        ¡Gracias por tu generosidad y apoyo a nuestra misión!
                    </p>

                    @* === AVISO PAYPAL PRÓXIMAMENTE (se elimina junto con el bloque SINPE al activar PayPal) === *@
                    <p class="text-muted small mt-3 mb-0">
                        💳 Muy pronto también podrás donar en línea con PayPal.
                    </p>
                    @* === FIN AVISO PAYPAL PRÓXIMAMENTE === *@
                </div>
                @* === FIN BLOQUE SINPE === *@

                @* === INICIO BLOQUE PAYPAL DESACTIVADO (descomentar cuando esté listo) ===
                NOTA: dentro de este comentario Razor las expresiones @ no se procesan.
                Al reactivar, recorda reemplazar las comillas internas de los ternarios.

                <div class="sion-dona-montos">
                    <button class="sion-monto-btn active" onclick="sionSeleccionarMonto(this)" data-monto="50">$50</button>
                    <button class="sion-monto-btn" onclick="sionSeleccionarMonto(this)" data-monto="100">$100</button>
                    <button class="sion-monto-btn" onclick="sionSeleccionarMonto(this)" data-monto="500">$500</button>
                </div>
                <div class="sion-dona-otro mt-3">
                    <label class="sion-form-label">O ingresá otro monto (USD)</label>
                    <div class="sion-dona-input-wrap">
                        <span class="sion-dona-prefix">$</span>
                        <input type="number" id="montoPersonalizado" class="sion-form-control sion-dona-input"
                               placeholder="0.00" min="1" step="1" />
                    </div>
                </div>
                ANTIFORGERY_TOKEN_AQUI
                <div class="sion-dona-paypal mt-4">
                    <p class="sion-dona-seguro">🔒 Pago seguro procesado por PayPal</p>
                    <div id="paypal-button-container"></div>
                    <div id="dona-exito" style="display:none" class="sion-dona-exito">
                        <span class="dona-exito-icon">✅</span>
                        <div>
                            <strong>¡Gracias por tu donación!</strong>
                            <p id="dona-exito-detalle" class="mb-0"></p>
                        </div>
                    </div>
                    <div id="dona-error" style="display:none" class="sion-dona-error">
                        <span>⚠️</span>
                        <p id="dona-error-msg" class="mb-0"></p>
                    </div>
                </div>
                === FIN BLOQUE PAYPAL DESACTIVADO *@
            </div>

            <!-- IMPACTO -->
            <div class="col-lg-6 sion-reveal-right">
                <span class="sion-badge">¿A dónde va tu donación?</span>
                <h2 class="mt-2 mb-4">Tu impacto en números</h2>

                <div class="sion-impacto-item">
                    <div class="sion-impacto-monto">$10</div>
                    <div>
                        <div class="sion-impacto-titulo">Útiles escolares</div>
                        <p class="sion-impacto-desc">Cubre los útiles escolares de un niño por un mes.</p>
                    </div>
                </div>

                <div class="sion-impacto-item">
                    <div class="sion-impacto-monto">$25</div>
                    <div>
                        <div class="sion-impacto-titulo">Alimentación</div>
                        <p class="sion-impacto-desc">Brinda meriendas nutritivas a 5 niños durante una semana.</p>
                    </div>
                </div>

                <div class="sion-impacto-item">
                    <div class="sion-impacto-monto">$50</div>
                    <div>
                        <div class="sion-impacto-titulo">Taller educativo</div>
                        <p class="sion-impacto-desc">Financia un taller completo de refuerzo escolar o deporte.</p>
                    </div>
                </div>

                <div class="sion-impacto-item">
                    <div class="sion-impacto-monto">$100</div>
                    <div>
                        <div class="sion-impacto-titulo">Apoyo familiar</div>
                        <p class="sion-impacto-desc">Apoya a una familia vulnerable durante un mes completo.</p>
                    </div>
                </div>

                <div class="sion-dona-confianza mt-4">
                    <p>🏛️ Entidad legalmente constituida en Costa Rica</p>
                    <p>📋 Transparencia total en el uso de recursos</p>
                    <p>❤️ 17 años de servicio continuo a la comunidad</p>
                </div>
            </div>

        </div>
    </div>
</section>

@section Scripts {
    @* PAYPAL SCRIPTS DESACTIVADOS — para reactivar: quitar el @* de esta línea y el correspondiente al final del bloque
    <script src="https://www.paypal.com/sdk/js?client-id=@Model.PayPalClientId&currency=USD"
            data-sdk-integration-source="button-factory"></script>
    <script>
        // ── Monto seleccionado ───────────────────────────────────────────────
        let montoSeleccionado = @(Model.Monto ?? 50);

        function sionSeleccionarMonto(btn) {
            document.querySelectorAll('.sion-monto-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            montoSeleccionado = parseFloat(btn.dataset.monto);
            document.getElementById('montoPersonalizado').value = '';
            reiniciarBotonPayPal();
        }

        document.getElementById('montoPersonalizado').addEventListener('input', function () {
            const val = parseFloat(this.value);
            if (val > 0) {
                document.querySelectorAll('.sion-monto-btn').forEach(b => b.classList.remove('active'));
                montoSeleccionado = val;
                reiniciarBotonPayPal();
            }
        });

        function obtenerMonto() {
            const personalizado = parseFloat(document.getElementById('montoPersonalizado').value);
            return personalizado > 0 ? personalizado : montoSeleccionado;
        }

        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';

        // ── Botón PayPal ─────────────────────────────────────────────────────
        function renderizarBotonPayPal() {
            paypal.Buttons({
                style: {
                    color:  'blue',
                    shape:  'rect',
                    label:  'donate',
                    height: 45
                },

                // Paso 1: crea la orden en nuestro servidor → PayPal
                createOrder: async () => {
                    const monto = obtenerMonto();
                    if (!monto || monto <= 0) {
                        alert('Por favor ingresá un monto válido.');
                        return;
                    }

                    const res = await fetch('?handler=CrearOrden', {
                        method:  'POST',
                        headers: {
                            'Content-Type':             'application/json',
                            'RequestVerificationToken': token
                        },
                        body: JSON.stringify({ monto })
                    });

                    const data = await res.json();
                    if (data.error) throw new Error(data.error);
                    return data.orderId;
                },

                // Paso 2: usuario aprobó → capturamos en nuestro servidor
                onApprove: async (data) => {
                    const res = await fetch('?handler=CapturarOrden', {
                        method:  'POST',
                        headers: {
                            'Content-Type':             'application/json',
                            'RequestVerificationToken': token
                        },
                        body: JSON.stringify({ orderId: data.orderID })
                    });

                    const resultado = await res.json();

                    document.getElementById('paypal-button-container').style.display = 'none';

                    if (resultado.exitoso) {
                        document.getElementById('dona-exito-detalle').textContent =
                            `Recibimos tu donación de $${resultado.monto} ${resultado.moneda}. ¡Gracias, ${resultado.nombreDonante || 'donante'}!`;
                        document.getElementById('dona-exito').style.display = 'flex';
                    } else {
                        document.getElementById('dona-error-msg').textContent =
                            resultado.error ?? 'Hubo un problema al procesar tu donación.';
                        document.getElementById('dona-error').style.display = 'flex';
                    }
                },

                onError: (err) => {
                    console.error('PayPal error:', err);
                    document.getElementById('dona-error-msg').textContent =
                        'Ocurrió un error con PayPal. Por favor intentá de nuevo.';
                    document.getElementById('dona-error').style.display = 'flex';
                },

                onCancel: () => {
                    // El usuario cerró el popup sin pagar — no hacemos nada
                }

            }).render('#paypal-button-container');
        }

        // Re-renderiza el botón si el monto cambia (PayPal SDK no lo actualiza solo)
        let renderTimeout;
        function reiniciarBotonPayPal() {
            clearTimeout(renderTimeout);
            renderTimeout = setTimeout(() => {
                const container = document.getElementById('paypal-button-container');
                container.innerHTML = '';
                renderizarBotonPayPal();
            }, 400);
        }

        renderizarBotonPayPal();
    </script>
    *@
}