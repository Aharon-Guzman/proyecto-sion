@page
@model Sion.PL.Pages.GaleriaModel
@{
    ViewData["Title"] = "Galería";
    ViewData["Description"] = "Conocé el trabajo de la Asociación Sion a través de nuestra galería de imágenes.";
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/glightbox/dist/css/glightbox.min.css" />
}

<!-- PAGE HERO -->
<section class="sion-page-hero">
    <div class="container sion-page-hero-content">
        <h1>Galería</h1>
        <p>Momentos que reflejan el impacto de nuestra comunidad en Concepción de Tres Ríos.</p>
    </div>
</section>

<!-- GALERÍA -->
<section class="sion-seccion">
    <div class="container sion-reveal">

        @if (!Model.Imagenes.Any())
        {
            <div class="text-center py-5">
                <p style="color:#aaa;font-size:1.1rem">Próximamente compartiremos imágenes de nuestras actividades.</p>
            </div>
        }
        else
        {
            <div class="row g-3">
                @foreach (var imagen in Model.Imagenes)
                {
                    <div class="col-6 col-md-4 col-lg-3">
                        <a href="@imagen.RutaWebP"
                           class="glightbox sion-galeria-thumb"
                           data-gallery="sion"
                           data-title="@imagen.Titulo">
                            <img src="@imagen.RutaThumbnail"
                                 alt="@imagen.Titulo"
                                 loading="lazy" />
                        </a>
                    </div>
                }
            </div>
        }

    </div>
</section>

<!-- CTA -->
<section class="sion-cta">
    <div class="container sion-reveal">
        <h2>Formá parte de la historia</h2>
        <p>Tu apoyo nos permite seguir transformando vidas en Concepción de Tres Ríos.</p>
        <a asp-page="/Donaciones" class="btn-sion-grande">Donar ahora</a>
    </div>
</section>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/glightbox/dist/js/glightbox.min.js"></script>
    <script>
        GLightbox({
            selector: '.glightbox',
            touchNavigation: true,
            loop: true,
            zoomable: true,
            closeButton: true
        });
    </script>
}