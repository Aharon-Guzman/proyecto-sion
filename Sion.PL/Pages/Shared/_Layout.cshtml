<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="@(ViewData["Description"] ?? "Asociación Sion — Transformando vidas en Tres Ríos, Costa Rica.")" />
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " — Sion" : "Asociación Sion")</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    @{
        var ruta = ViewContext.RouteData.Values["page"]?.ToString() ?? string.Empty;
    }

    <!-- ========== NAVBAR ========== -->
    <nav class="navbar navbar-expand-lg sticky-top sion-navbar" aria-label="Navegación principal">
        <div class="container">

            <a class="navbar-brand sion-brand" asp-page="/Index" aria-label="Inicio — Asociación Sion">
                SION
            </a>

            <button class="sion-ham" id="sionHamBtn" type="button"
                    data-bs-toggle="collapse" data-bs-target="#navbarMain"
                    aria-controls="navbarMain" aria-expanded="false" aria-label="Abrir menú">
                <span></span>
                <span></span>
                <span></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarMain">
                <ul class="navbar-nav ms-auto align-items-center">
                    <li class="nav-item">
                        <a class="nav-link @(ruta == "/Index" ? "sion-nav-active" : "")"
                           asp-page="/Index"
                           aria-current="@(ruta == "/Index" ? "page" : null)">Inicio</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ruta == "/Nosotros" ? "sion-nav-active" : "")"
                           asp-page="/Nosotros"
                           aria-current="@(ruta == "/Nosotros" ? "page" : null)">Nosotros</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ruta == "/Galeria" ? "sion-nav-active" : "")"
                           asp-page="/Galeria"
                           aria-current="@(ruta == "/Galeria" ? "page" : null)">Galería</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ruta == "/Contacto" ? "sion-nav-active" : "")"
                           asp-page="/Contacto"
                           aria-current="@(ruta == "/Contacto" ? "page" : null)">Contacto</a>
                    </li>
                    <li class="nav-item ms-2">
                        <a class="nav-link btn-dona @(ruta == "/Donaciones" ? "btn-dona-active" : "")"
                           asp-page="/Donaciones">Donar</a>
                    </li>
                </ul>
            </div>

        </div>
    </nav>
    <!-- ========== FIN NAVBAR ========== -->

    <!-- ========== CONTENIDO PRINCIPAL ========== -->
    <main>
        @RenderBody()
    </main>
    <!-- ========== FIN CONTENIDO ========== -->

    <!-- ========== FOOTER ========== -->
    <footer class="sion-footer" aria-label="Pie de página">
        <div class="container">
            <p class="sion-footer-logo">SION</p>
            <p>Concepción de Tres Ríos, Cartago, Costa Rica</p>
            <p>
                <a href="mailto:info@sioncr.org">info@sioncr.org</a>
                &nbsp;&middot;&nbsp;
                <a href="tel:+50600000000">+506 0000-0000</a>
            </p>
            <p class="sion-footer-copy">
                &copy; @DateTime.Now.Year Asociación Sion &nbsp;&middot;&nbsp;
                <a href="https://sioncr.org" target="_blank" rel="noopener">sioncr.org</a>
            </p>
        </div>
    </footer>
    <!-- ========== FIN FOOTER ========== -->

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
