<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO básico -->
    <meta name="description" content="@(ViewData["Description"] ?? "Proyecto Sion — Transformando vidas en Concepción de Tres Ríos, Cartago, Costa Rica desde 2008.")" />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Proyecto Sion" />

    <!-- Open Graph (WhatsApp, Facebook, LinkedIn) -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Proyecto Sion" />
    <meta property="og:title" content="@(ViewData["Title"] != null ? ViewData["Title"] + " — Sion" : "Proyecto Sion")" />
    <meta property="og:description" content="@(ViewData["Description"] ?? "Proyecto Sion — Transformando vidas en Concepción de Tres Ríos, Cartago, Costa Rica desde 2008.")" />
    <meta property="og:image" content="https://sioncr.org/images/og-image.jpg" />
    <meta property="og:url" content="https://sioncr.org@(Context.Request.Path)" />
    <meta property="og:locale" content="es_CR" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@(ViewData["Title"] != null ? ViewData["Title"] + " — Sion" : "Proyecto Sion")" />
    <meta name="twitter:description" content="@(ViewData["Description"] ?? "Proyecto Sion — Transformando vidas en Concepción de Tres Ríos, Cartago, Costa Rica desde 2008.")" />
    <meta name="twitter:image" content="https://sioncr.org/images/og-image.jpg" />

    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " — Sion" : "Proyecto Sion")</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="canonical" href="https://sioncr.org@(Context.Request.Path)" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    @{
        var ruta = ViewContext.RouteData.Values["page"]?.ToString() ?? string.Empty;
    }

    <!-- ========== NAVBAR ========== -->
    <nav class="navbar navbar-expand-lg sticky-top sion-navbar" aria-label="Navegación principal">
        <div class="container">

            <a class="navbar-brand sion-brand" asp-page="/Index" aria-label="Inicio — Proyecto Sion">
                <img src="~/images/Logo sin letras.png" alt="" class="sion-navbar-logo" aria-hidden="true" />
                <span class="sion-navbar-brand-text">Proyecto Social Sion</span>
            </a>

            <button class="sion-ham d-lg-none" id="sionHamBtn" type="button"
                    data-bs-toggle="collapse" data-bs-target="#navbarMain"
                    aria-controls="navbarMain" aria-expanded="false" aria-label="Abrir menú">
                <span></span>
                <span></span>
                <span></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarMain">
                <ul class="navbar-nav ms-auto align-items-center">
                    <li class="nav-item">
                        <a class="nav-link @(ruta == "/Index" ? "sion-nav-active" : "")"
                           asp-page="/Index"
                           aria-current="@(ruta == "/Index" ? "page" : null)">Inicio</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ruta == "/Nosotros" ? "sion-nav-active" : "")"
                           asp-page="/Nosotros"
                           aria-current="@(ruta == "/Nosotros" ? "page" : null)">Nosotros</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ruta == "/Galeria" ? "sion-nav-active" : "")"
                           asp-page="/Galeria"
                           aria-current="@(ruta == "/Galeria" ? "page" : null)">Galería</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ruta == "/Contacto" ? "sion-nav-active" : "")"
                           asp-page="/Contacto"
                           aria-current="@(ruta == "/Contacto" ? "page" : null)">Contacto</a>
                    </li>
                    <li class="nav-item ms-2">
                        <a class="nav-link btn-dona @(ruta == "/Donaciones" ? "btn-dona-active" : "")"
                           asp-page="/Donaciones">Donar</a>
                    </li>
                </ul>
            </div>

        </div>
    </nav>
    <!-- ========== FIN NAVBAR ========== -->

    <!-- ========== CONTENIDO PRINCIPAL ========== -->
    <main>
        @RenderBody()
    </main>
    <!-- ========== FIN CONTENIDO ========== -->

    <!-- ========== FOOTER ========== -->
    <footer class="sion-footer" aria-label="Pie de página">
        <div class="container">
            <p class="sion-footer-logo">SION</p>
            <p>Concepción de Tres Ríos, Cartago, Costa Rica</p>
            <p>
                <a href="mailto:info@sioncr.org">info@sioncr.org</a>
                &nbsp;&middot;&nbsp;
                <a href="https://wa.me/50688502694" target="_blank" rel="noopener">+506 8850-2694</a>
            </p>
            <p>
                <a href="https://www.facebook.com/people/Proyecto-Sion/100064749126423/" target="_blank" rel="noopener" class="sion-footer-social" aria-label="Facebook de Proyecto Sion">
                    <i class="bi bi-facebook"></i>
                </a>
            </p>
            <p class="sion-footer-copy">
                &copy; @DateTime.Now.Year Proyecto Sion &nbsp;&middot;&nbsp;
                <a asp-page="/Index">sioncr.org</a>
            </p>
        </div>
    </footer>
    <!-- ========== FIN FOOTER ========== -->

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
